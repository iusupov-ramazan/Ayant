# Copy this file to keystore.properties (which is gitignored) and fill in your
# release signing details, then run:  ./gradlew :app:assembleRelease  (or bundleRelease)
#
# Create a keystore once with:
#   keytool -genkey -v -keystore ayant-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias ayant
#
storeFile=../ayant-release.jks
storePassword=CHANGE_ME
keyAlias=ayant
keyPassword=CHANGE_ME
