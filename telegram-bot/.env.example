# Токен бота от @BotFather (обязательно)
TELEGRAM_BOT_TOKEN=

# Бесплатный ключ ИИ от Groq: https://console.groq.com/keys
# Без ключа бот всё равно работает, но отвечает только по FAQ.
GROQ_API_KEY=

# Модель Groq (по умолчанию llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Контакт живой поддержки (бот предложит его, если не знает ответа)
SUPPORT_CONTACT=ostepp1@gmail.com
