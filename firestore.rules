rules_version = '2';

// Правила доступа для каталога САН.
// Чтение каталога — публичное (лента работает и для гостей).
// Запись — только аутентифицированным (админ / хост).
service cloud.firestore {
  match /databases/{database}/documents {

    // Заведения и предложения теперь хранят ownerID (uid владельца-хоста).
    // Пока запись разрешена любому аутентифицированному (нужно для админ-панели).
    // Когда появятся роли, можно ужесточить, напр.:
    //   allow write: if request.auth != null &&
    //     (request.resource.data.ownerID == request.auth.uid || isAdmin());
    match /venues/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /deals/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Новая коллекция отзывов — без неё in-app чтение падало с permission-denied.
    match /reviews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Push-кампании: хост создаёт ("pending"); админ-панель читает и одобряет
    // (status → approved/rejected). Рассылку делает Cloud Function по одобрению.
    match /pushCampaigns/{id} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Аналитика: любой аутентифицированный логирует события; читает владелец/админ.
    match /analytics/{venueID}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Профили хостов: хост пишет свой, админ выставляет верификацию.
    match /hosts/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // FCM-токены пользователей (для адресной рассылки с частотным лимитом).
    match /userTokens/{token} {
      allow write: if request.auth != null;
      allow read: if false;
    }

    // Погашения купонов: пользователь создаёт документ (id = uid_dealID).
    // Счётчик и пометку "counted" делает Cloud Function (admin SDK обходит правила).
    match /redemptions/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Рефералы: приглашённый создаёт документ referrals/{его uid}.
    // Награду пригласившему начисляет Cloud Function.
    match /referrals/{inviteeID} {
      allow create: if request.auth != null && request.auth.uid == inviteeID;
      allow read, update, delete: if false;
    }

    // Начисленные сервером бонусы: пользователь читает свои и помечает claimed.
    // Создаёт только Cloud Function (admin SDK).
    match /bonusGrants/{id} {
      allow read: if request.auth != null && resource.data.userID == request.auth.uid;
      allow update: if request.auth != null && resource.data.userID == request.auth.uid
                    && request.resource.data.userID == resource.data.userID;
      allow create, delete: if false;
    }

    // Подарочные купоны: создаёт даритель, забирает получатель (помечает claimed).
    match /giftCoupons/{code} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Купоны пользователя (бэкенд-трекинг). Пользователь создаёт свои (deal-купоны),
    // читает свои. Пометку used ставит только Cloud Function scanCoupon (admin SDK
    // обходит правила) — поэтому update/delete из клиента запрещены (анти-чит).
    // Купоны-награды лояльности тоже создаёт Cloud Function.
    match /coupons/{id} {
      allow read:   if request.auth != null && resource.data.userID == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userID == request.auth.uid
                    && request.resource.data.used == false;
      allow update, delete: if false;
    }

    // Карты лояльности гостей: гость читает свои; пишет только Cloud Function.
    match /loyaltyCards/{id} {
      allow read:  if request.auth != null && resource.data.userID == request.auth.uid;
      allow write: if false;
    }
  }
}
