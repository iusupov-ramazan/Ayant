rules_version = '2';

// Правила доступа для каталога САН.
// Чтение каталога — публичное (лента работает и для гостей).
// Запись каталога — только владелец-хост (по ownerID) или админ (custom claim).
//
// Роль администратора выдаётся через кастомный claim `admin: true`
// (см. scripts/set-admin-claim.js). Раньше запись была разрешена ЛЮБОМУ
// аутентифицированному пользователю — теперь это закрыто.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Хелперы ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    // Админ определяется кастомным claim'ом (выдаётся серверным скриптом).
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    function uid() {
      return request.auth.uid;
    }
    // Владелец заведения (по документу venues/{venueID}).
    function isVenueOwner(venueID) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/venues/$(venueID))
        && get(/databases/$(database)/documents/venues/$(venueID)).data.ownerID == uid();
    }
    // Создаваемый/изменяемый документ принадлежит текущему хосту.
    function ownsIncoming() {
      return isSignedIn() && request.resource.data.ownerID == uid();
    }
    function ownsExisting() {
      return isSignedIn() && resource.data.ownerID == uid();
    }

    // ── Заведения ────────────────────────────────────────────────────────
    // Читают все. Создаёт/меняет владелец (ownerID == uid) или админ.
    // При создании ownerID обязателен и должен совпадать с uid (кроме админа).
    match /venues/{id} {
      allow read: if true;
      allow create: if isAdmin() || (ownsIncoming() && request.resource.data.ownerID is string);
      allow update: if isAdmin() || (ownsExisting() && request.resource.data.ownerID == resource.data.ownerID);
      allow delete: if isAdmin() || ownsExisting();
    }

    // ── Предложения (акции) ──────────────────────────────────────────────
    match /deals/{id} {
      allow read: if true;
      allow create: if isAdmin() || (ownsIncoming() && request.resource.data.ownerID is string);
      allow update: if isAdmin() || (ownsExisting() && request.resource.data.ownerID == resource.data.ownerID);
      allow delete: if isAdmin() || ownsExisting();
    }

    // ── Категории заведений ──────────────────────────────────────────────
    // Гибкий список, управляется только из админ-панели. Читают все.
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Отзывы ───────────────────────────────────────────────────────────
    // Читают все. Создаёт автор (authorID == uid). Менять/удалять может автор,
    // владелец заведения (ответ хоста hostReply) или админ.
    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorID == uid();
      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.authorID == uid())
                    || isVenueOwner(resource.data.venueID);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorID == uid());
    }

    // ── Push-кампании ────────────────────────────────────────────────────
    // Хост создаёт кампанию по своему заведению ("pending"). Одобряет только
    // админ (status → approved/rejected); рассылку делает Cloud Function.
    // Кампанию создаёт любой аутентифицированный хост ("pending"); это безвредно,
    // т.к. рассылку запускает только Cloud Function ПОСЛЕ одобрения админом
    // (update разрешён только админу). Владение заведением тут проверять нельзя:
    // Android-хост не пишет venues в Firestore (только в SharedPreferences), а у
    // засеянных заведений ownerID пустой — проверка isVenueOwner их бы заблокировала.
    match /pushCampaigns/{id} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Аналитика ────────────────────────────────────────────────────────
    // Документы analytics/{venueID}/days/{day} — счётчики событий (increment),
    // которые пишет клиент-телеметрия. Читает статистику только владелец
    // заведения или админ. Чувствительные счётчики (погашения) идут не сюда,
    // а через Cloud Function countRedemption (admin SDK).
    // TODO: перенести запись телеметрии в Cloud Function, тогда write закрыть.
    match /analytics/{venueID}/{document=**} {
      allow read:  if isAdmin() || isVenueOwner(venueID);
      allow write: if isSignedIn();
    }

    // ── Профили хостов ───────────────────────────────────────────────────
    // Читают аутентифицированные (приложение показывает статус верификации).
    // Пишет хост свой профиль (uid == документ). Статус верификации — строковое
    // поле `verification` (none|pending|verified|rejected). Хост может лишь
    // ЗАПРОСИТЬ верификацию (none/pending); выставить verified/rejected — только
    // админ. Уже верифицированный хост может править прочие поля, не трогая статус.
    match /hosts/{hostUid} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
                    || (isSignedIn() && hostUid == uid()
                        && request.resource.data.get('verification', 'none') in ['none', 'pending']);
      allow update: if isAdmin()
                    || (isSignedIn() && hostUid == uid()
                        && (request.resource.data.get('verification', 'none') == resource.data.get('verification', 'none')
                            || request.resource.data.get('verification', 'none') in ['none', 'pending']));
      allow delete: if isAdmin();
    }

    // ── FCM-токены пользователей ─────────────────────────────────────────
    match /userTokens/{token} {
      allow write: if isSignedIn();
      allow read: if false;
    }

    // ── Погашения купонов ────────────────────────────────────────────────
    // Пользователь создаёт документ (id = uid_dealID). Счётчик и пометку
    // "counted" делает Cloud Function (admin SDK обходит правила).
    match /redemptions/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // ── Рефералы ─────────────────────────────────────────────────────────
    match /referrals/{inviteeID} {
      allow create: if isSignedIn() && uid() == inviteeID;
      allow read, update, delete: if false;
    }

    // ── Серверные бонусы ─────────────────────────────────────────────────
    match /bonusGrants/{id} {
      allow read: if isSignedIn() && resource.data.userID == uid();
      allow update: if isSignedIn() && resource.data.userID == uid()
                    && request.resource.data.userID == resource.data.userID;
      allow create, delete: if false;
    }

    // ── Подарочные купоны ────────────────────────────────────────────────
    // Купон адресуется по коду-ссылке (без uid получателя). Забрать можно РОВНО
    // один раз: update разрешён только как переход claimed false→true и без
    // подмены остального содержимого — иначе купон можно было бы «перезабрать».
    match /giftCoupons/{code} {
      allow create: if isSignedIn() && request.resource.data.get('claimed', false) == false;
      allow read:   if isSignedIn();
      allow update: if isSignedIn()
                    && resource.data.get('claimed', false) == false
                    && request.resource.data.claimed == true
                    && request.resource.data.title == resource.data.title
                    && request.resource.data.code == resource.data.code
                    && request.resource.data.get('fromName', '') == resource.data.get('fromName', '');
      allow delete: if false;
    }

    // ── Купоны пользователя (анти-чит) ───────────────────────────────────
    // Пометку used ставит только Cloud Function scanCoupon (admin SDK).
    match /coupons/{id} {
      allow read:   if isSignedIn() && resource.data.userID == uid();
      allow create: if isSignedIn() && request.resource.data.userID == uid()
                    && request.resource.data.used == false;
      allow update, delete: if false;
    }

    // ── Карты лояльности ─────────────────────────────────────────────────
    match /loyaltyCards/{id} {
      allow read:  if isSignedIn() && resource.data.userID == uid();
      allow write: if false;
    }
  }
}
